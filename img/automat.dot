digraph G {
  rankdir=LR;

  start [shape=point, label=""];
  node [shape=circle, fontsize=18];
  q0 [label="0"];
  q1 [label="1"];
  q2 [label="2"];
  q3 [label="3"];
  q4 [label="4"];
  q5 [label="5"];
  q6 [label="6"];
  q7 [label="7"];

  start -> q0;

  q0 -> q1 [label="a"];
  q0 -> q6 [label="b"];

  q1 -> q2 [label="a"];
  q1 -> q4 [label="b"];

  q6 -> q7 [label="a, b"];

  q2 -> q3 [label="a"];
  q2 -> q5 [label="b"];

  q4 -> q7 [label="a, b"];
  
  q7 -> q7 [label="a, b"];

  q3 -> q1 [label="a"];
  q3 -> q6 [label="b"];

  q5 -> q7 [label="a, b"];
}